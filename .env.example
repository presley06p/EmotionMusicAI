# ── EmoTune AI — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# Flask
SECRET_KEY=change-me-to-a-long-random-string-in-production
FLASK_ENV=development     # Set to "production" for deployment
DB_PATH=database.db

# Spotify Web API
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create an app
# 3. Copy Client ID and Client Secret here
# 4. Add the redirect URI in the Spotify app settings
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:5000/spotify/callback
